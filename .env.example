#
# App e hub
#
YTS_APP_NAME=YTS Render
YTS_APP_URL=http://127.0.0.1:8080
YTS_APP_HOST=127.0.0.1
YTS_APP_PORT=8080
YTS_HUB_AUTH_TOKEN=

#
# Persistencia
#
YTS_DATA_DIR=data
YTS_DATABASE_URL=sqlite:///data/yts_render.db
YTS_SQLITE_BUSY_TIMEOUT_MS=30000
YTS_SQLITE_JOURNAL_MODE=WAL
YTS_SQLITE_SYNCHRONOUS=NORMAL
YTS_SCHEMA_VERSION=1.0.0

#
# Defaults editoriais
#
YTS_NICHE_ID=curiosidades
YTS_LANGUAGE=pt-BR
YTS_TARGET_DURATION_SEC=45
YTS_SCENE_TARGET_COUNT=6
YTS_SIMPLE_SHORTS_MODE=true

#
# LLM e pipeline principal
#
YTS_USE_MOCK_PROVIDERS=false
YTS_STRICT_MINIMAX_VALIDATION=false
YTS_LLM_PRIMARY_PROVIDER=minimax
YTS_LLM_FALLBACK_PROVIDER=deepseek
YTS_LLM_REPAIR_PROVIDER=deepseek
YTS_LLM_SCENE_PROVIDER=deepseek
YTS_LLM_ENABLE_FALLBACK=true
YTS_LLM_SCRIPT_DRAFT_PROVIDER=deepseek
YTS_LLM_SCRIPT_REPAIR_ATTEMPTS=1
YTS_LLM_TOPIC_REPAIR_ATTEMPTS=2
YTS_LLM_TOPIC_TIMEOUT_SEC=75
YTS_LLM_SCRIPT_DRAFT_TIMEOUT_SEC=45
YTS_MINIMAX_SCRIPT_TIMEOUT_SEC=150
YTS_LLM_PUBLISH_AUDIT_TIMEOUT_SEC=75
YTS_REAL_RUN_ALLOW_MOCK_FALLBACK=false
YTS_SCENE_PROMPT_GATE_ENABLED=true
YTS_ASSET_SEMANTIC_THRESHOLD=0.80
YTS_ASSET_TOTAL_THRESHOLD=0.75
YTS_RENDER_MIN_BITRATE=250000
YTS_ASSET_GENERATION_TIMEOUT_SEC=75
YTS_ASSET_GENERATION_REGENERATION_ROUNDS=2
YTS_ASSET_GENERATION_PARALLELISM=3

#
# Audio
#
YTS_BACKGROUND_MUSIC_ENABLED=true
YTS_BACKGROUND_MUSIC_GAIN_DB=-20.0
YTS_SOUND_DESIGN_ENABLED=false
YTS_SOUND_DESIGN_GAIN_DB=-18.0

#
# YouTube
#
YTS_YOUTUBE_PUBLISH_MODE=manual
YTS_YOUTUBE_API_ENABLED=false
YTS_YOUTUBE_CHANNEL_ID=
YTS_YOUTUBE_CLIENT_ID=
YTS_YOUTUBE_CLIENT_SECRET=
YTS_YOUTUBE_OAUTH_REDIRECT_URI=
YTS_YOUTUBE_NOTIFY_SUBSCRIBERS=false

#
# Direitos e disclosure
#
YTS_MINIMAX_COMMERCIAL_RIGHTS_CONFIRMED=false
YTS_EDGE_TTS_COMMERCIAL_RIGHTS_CONFIRMED=false
YTS_MINIMAX_RIGHTS_EVIDENCE_URL=
YTS_EDGE_TTS_RIGHTS_EVIDENCE_URL=
YTS_ALLOW_SYNTHETIC_VISUALS_FOR_MONETIZATION=true
YTS_CONSERVATIVE_SYNTHETIC_DISCLOSURE=true
YTS_CHANNEL_AI_GENERATED_CONTENT=true
YTS_AI_GENERATED_COMMERCIAL_RIGHTS_CONFIRMED=true

#
# MiniMax
#
YTS_MINIMAX_API_KEY=
YTS_MINIMAX_TEXT_API_KEY=
# Image generation first uses YTS_MINIMAX_TEXT_API_KEY; this dedicated key is used only after quota/rate-limit on the text key, or directly when no text key exists.
YTS_MINIMAX_IMAGE_API_KEY=
YTS_MINIMAX_MUSIC_API_KEY=
YTS_MINIMAX_TEXT_BASE_URL=https://api.minimax.io/v1
YTS_MINIMAX_IMAGE_BASE_URL=https://api.minimax.io/v1/image_generation
YTS_MINIMAX_MUSIC_BASE_URL=https://api.minimax.io/v1
YTS_MINIMAX_TEXT_TIMEOUT_SEC=180
YTS_MINIMAX_MUSIC_TIMEOUT_SEC=240
YTS_MINIMAX_SCENE_PLAN_TIMEOUT_SEC=120
YTS_LLM_SCENE_PLAN_TIMEOUT_SEC=75

#
# OpenAI
#
YTS_OPENAI_API_KEY=
YTS_OPENAI_BASE_URL=https://api.openai.com/v1
YTS_OPENAI_MODEL=gpt-5.4
YTS_OPENAI_TIMEOUT_SEC=180

#
# DeepSeek
#
YTS_DEEPSEEK_API_KEY=
YTS_DEEPSEEK_BASE_URL=https://api.deepseek.com
YTS_DEEPSEEK_MODEL=deepseek-v4-flash
YTS_DEEPSEEK_TIMEOUT_SEC=90

#
# Qwen
#
YTS_QWEN_API_KEY=
YTS_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
YTS_QWEN_MODEL=qwen3.6-max-preview
YTS_QWEN_TIMEOUT_SEC=90

#
# Stock fallback
#
YTS_PEXELS_API_KEY=
YTS_PIXABAY_API_KEY=

#
# Worker
#
YTS_WORKER_POLL_SECONDS=1.0
YTS_JOB_LEASE_SECONDS=60

#
# Retencao de artefatos temporarios
#
YTS_ARTIFACT_RETENTION_ENABLED=true
YTS_ARTIFACT_RETENTION_SWEEP_SECONDS=60
YTS_ARTIFACT_TTL_HARD_FAILURE_HOURS=24
YTS_ARTIFACT_TTL_RECOVERABLE_HOURS=168
YTS_ARTIFACT_TTL_PUBLISHABLE_HOURS=504

#
# Exposicao e operacao
#
YTS_TAILSCALE_HOSTNAME=shorts-hub
YTS_TAILNET_DOMAIN=example.ts.net
